# Harold — multi-stage build
# Stage 1: build and test
# Stage 2: lean production image (only dist/ + prod deps)

# --- Build stage ---
FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# Tests must pass before the production image is finalized
COPY test ./test
COPY vitest.config.ts ./
RUN npm test

# --- Production stage ---
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist
COPY docker/entrypoint.sh ./docker/entrypoint.sh
RUN chmod +x docker/entrypoint.sh

ENV TZ=Asia/Taipei \
    LOG_LEVEL=info

ENTRYPOINT ["/app/docker/entrypoint.sh"]
