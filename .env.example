# Harold configuration — copy to .env and fill in your values.
# docker compose reads this via env_file: .env

# -----------------------------------------------------------------------
# Telegram
# 1. Create a bot: message @BotFather on Telegram, use /newbot
# 2. Get your chat_id: message @userinfobot or send a message to your bot
#    then call: https://api.telegram.org/bot<TOKEN>/getUpdates
# -----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------
# Google AI Studio — used only for message humanization (free tier)
# Get your key at: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------
GOOGLE_AI_STUDIO_API_KEY=
# Recommended free-tier model
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------
# Location — used by weather scripts (Open-Meteo, no API key required)
# Defaults to Taipei. Find your coordinates: https://www.latlong.net
# -----------------------------------------------------------------------
LATITUDE=25.0330
LONGITUDE=121.5654

# -----------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------
# IANA timezone name — cron schedules are interpreted in this timezone
TZ=Asia/Taipei

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------
# Dashboard — web UI showing registered jobs with manual trigger buttons
# -----------------------------------------------------------------------
DASHBOARD_PORT=8080

# -----------------------------------------------------------------------
# Watchtower — polls ghcr.io and redeploys harold when a new image lands
# Uses 6-field cron (seconds minutes hours day month weekday) or descriptors:
#   @hourly / @daily / @weekly
# Default: once per hour
# -----------------------------------------------------------------------
WATCHTOWER_SCHEDULE=@hourly
